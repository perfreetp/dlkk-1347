{
  "name": "log-analyzer-desktop",
  "version": "1.0.0",
  "description": "日志分析桌面客户端 - 供客服支持和测试人员排查问题",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite --host",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7",
    "dayjs": "^1.11.10",
    "jszip": "^3.10.1",
    "file-saver": "^2.0.5",
    "clsx": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "electron": "^27.1.0",
    "electron-builder": "^24.6.4",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "tailwindcss": "^3.3.5",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16"
  },
  "build": {
    "appId": "com.loganalyzer.desktop",
    "productName": "LogAnalyzer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
